{
  "name": "ins-snap-resolver",
  "version": "0.1.0",
  "description": "MetaMask Snap for native .igra name resolution via INS (Igra Name Service) on Igra L2",
  "main": "dist/snap.js",
  "files": [
    "dist/",
    "snap.manifest.json",
    "images/"
  ],
  "scripts": {
    "build": "mm-snap build",
    "serve": "mm-snap serve",
    "watch": "mm-snap watch",
    "clean": "rimraf dist .cache"
  },
  "keywords": [
    "metamask",
    "snap",
    "ins",
    "igra",
    "kaspa",
    "name-service",
    "ens"
  ],
  "license": "MIT",
  "homepage": "https://insdomains.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsGoonBoyCrypto/INSdomains.git"
  },
  "bugs": {
    "url": "https://github.com/ItsGoonBoyCrypto/INSdomains/issues"
  },
  "dependencies": {
    "@metamask/snaps-sdk": "^11.1.1"
  },
  "devDependencies": {
    "@metamask/snaps-cli": "^8.4.1",
    "@metamask/snaps-utils": "^12.2.1",
    "@types/node": "^20.10.0",
    "prettier": "^3.8.3",
    "rimraf": "^5.0.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
