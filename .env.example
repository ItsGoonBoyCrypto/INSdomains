NEXT_PUBLIC_IGRA_RPC=https://rpc.igralabs.com:8545
NEXT_PUBLIC_IGRA_EXPLORER=https://explorer.igralabs.com

# ── Contracts (fill after deploy) ─────────────────────────
# Live addresses (Igra mainnet 38833):
# ── .ins TLD ──
NEXT_PUBLIC_INS_REGISTRY=0x535ff4A6710C2b0d087c5afF01b16fE10bC34D46
NEXT_PUBLIC_INS_RESOLVER=0x451D84002cE0eCFd4cc622c72FA40849a8Bb5f2A
NEXT_PUBLIC_INS_REVERSE_RESOLVER=0x9afb263be198c35159FafDafa0729Fc8B13562DA
NEXT_PUBLIC_INS_MARKETPLACE=0xf9e41e0a6fa04B641F6Cf8C92562C551034Af9F7
# ── .igra TLD ──
NEXT_PUBLIC_INS_REGISTRY_IGRA=0x42c2f5AA0c4aACfD07e5fBe65B898212c1c2879c
NEXT_PUBLIC_INS_REVERSE_RESOLVER_IGRA=0x1bbd46aec04330a90832faf1da91889dee67d931
NEXT_PUBLIC_INS_MARKETPLACE_IGRA=0xde8df276e93394c0e5dd9fe7a7ff6fd144a3642a
# ── .ikas TLD ──
NEXT_PUBLIC_INS_REGISTRY_IKAS=0xe705e38DeF4970e23617d30D9774062FEeEBA610
NEXT_PUBLIC_INS_REVERSE_RESOLVER_IKAS=0x9963aa24327f513b4cd5ce8118027a1da2fe76b5
