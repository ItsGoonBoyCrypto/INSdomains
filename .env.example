# ── Admin wallet (owns INSRegistry) ──────────────────────
# Set to the deploy wallet (or the multisig after ownership transfer).
# The /admin dashboard is gated by this address.
NEXT_PUBLIC_ADMIN_WALLET=0x0000000000000000000000000000000000000000

# ── WalletConnect (reuse shared project) ─────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=da4b947de90f58877efd397f439abbcb

# ── AI suggestions (server-only) ─────────────────────────
ANTHROPIC_API_KEY=

# ── Pricing (display base — tiers are on-chain) ──────────
NEXT_PUBLIC_BASE_PRICE_IKAS=10

# ── CCIP-Read gateway (server-only — disabled by default) ─
# When all 4 are set, /api/ccip/[sender]/[data].json serves signed
# offchain responses to the L1 wildcard resolver at CCIP_WILDCARD_L1_ADDRESS.
# This makes `*.<CCIP_PARENT_NAME>` resolve in every ENS-aware wallet
# (Rabby, regular MetaMask, Uniswap, Coinbase Wallet, Frame, Brave, etc.)
# via on-chain ENS resolver pointed at the wildcard contract.
#
# IMPORTANT: CCIP_PARENT_NAME must match whatever .eth name you set the
# resolver on (e.g. "insdomains.eth"). If unset, defaults to "igra.eth" —
# which won't match if you used a different parent. Symptom: gateway
# returns HTTP 200 with empty result (signed-zero), wallets show null.
CCIP_GATEWAY_ENABLED=false
CCIP_SIGNER_PRIVATE_KEY=
CCIP_WILDCARD_L1_ADDRESS=
CCIP_PARENT_NAME=insdomains.eth
CCIP_TTL_SECONDS=300
